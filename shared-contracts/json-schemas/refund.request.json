{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Refund Request",
  "type": "object",
  "properties": {
    "charge_id": { "type": "string", "format": "uuid" },
    "amount": { "type": "number", "minimum": 0.01 },
    "reason": { "type": "string" }
  },
  "required": ["charge_id", "amount"]
}
