# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_DB=gateway

# Application Database Credentials (for local dev, docker-compose uses POSTGRES_USER/PASSWORD)
DB_USER=postgres
DB_PASS=replace_with_secure_password
DB_HOST=localhost
DB_PORT=5432
DB_POOL_SIZE=10

# Vault Configuration
VAULT_DEV_TOKEN=replace_with_secure_token

# Webhook Security
WEBHOOK_SECRET=replace_with_high_entropy_random_string
WEBHOOK_SIGNATURE_HEADER=x-webhook-signature
WEBHOOK_IDEMPOTENCY_HEADER=x-idempotency-key
WEBHOOK_TIMESTAMP_HEADER=x-webhook-timestamp
WEBHOOK_MAX_SKEW_MS=300000

# HSM Configuration
HSM_PIN=replace_with_hsm_pin
HSM_SLOT=SLOT_0

# JWT Configuration (Paths or Content)
JWT_PRIVATE_KEY_PATH=/etc/secrets/private_key.pem
JWT_PUBLIC_KEY_PATH=/etc/secrets/public_key.pem
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
